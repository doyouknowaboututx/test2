--## GET THUMBNAIL URL FROM RBXASSETID
local function getThumbnailURL(assetString)
    local assetId = type(assetString) == "string" and assetString:match("rbxassetid://(%d+)")
    if not assetId then
        return nil
    end

    local apiUrl = string.format(
        "https://thumbnails.roblox.com/v1/assets?assetIds=%s&type=Asset&size=420x420&format=Png",
        assetId
    )

    local success, result = pcall(function()
        local raw = game:HttpGet(apiUrl)
        local decoded = svc.HttpService:JSONDecode(raw)
        return decoded and decoded.data and decoded.data[1] and decoded.data[1].imageUrl
    end)

    if success then
        return result
    end

    return nil
end

--## GET FISH INFO
local function getFishInfo(fishName)
    for _, fish in ipairs(FishNames) do
        if fish.Name == fishName then
            return fish
        end
    end
    return nil
end

--## GET FISH IMAGE
local function getFishImage(fishName)
    local fishInfo = getFishInfo(fishName)
    if not fishInfo or not fishInfo.Icon then
        return nil
    end

    return getThumbnailURL(fishInfo.Icon)
end

--## SEND WEBHOOK
local function sendWebhook(url, payload)
    if not url or url == "" then
        return
    end

    local success, err = pcall(function()
        httpRequest({
            Url = url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
            },
            Body = svc.HttpService:JSONEncode(payload),
        })
    end)

    if not success then
        warn("Failed send webhook: " .. tostring(err))
    end
end

--## PARSE FISH SERVER MESSAGE
local function parseFishMessage(text)
    text = text:gsub("<[^>]+>", "")
    text = text:gsub("%[Server%]:%s*", "")

    local username = text:match("^(.-) obtained")
    local fullFish = text:match("obtained an? (.-) %(")
    local weight = text:match("%((.-)%)")
    local rarity = text:match("with an? (.-) [cC]hance!?")

    if not fullFish then
        fullFish = text:match("obtained an? (.+)")
    end

    if not username or not fullFish then
        return nil
    end

    local sizeFound
    for _, size in ipairs(Sizes) do
        if fullFish:find(size, 1, true) then
            sizeFound = size
            fullFish = fullFish:gsub(size .. "%s*", "", 1)
            break
        end
    end

    local variantFound
    for _, variant in ipairs(Variants) do
        if fullFish:lower():find(variant:lower(), 1, true) then
            variantFound = variant
            fullFish = fullFish:gsub(variant .. "%s*", "", 1)
            break
        end
    end

    fullFish = fullFish:gsub("^%s+", ""):gsub("%s+$", "")

    local fishInfo = getFishInfo(fullFish)

    return {
        Player = username,
        Fish = fullFish,
        Size = sizeFound,
        Variant = variantFound,
        Weight = weight,
        Rarity = rarity,
        Tier = fishInfo and fishInfo.Tier or "Unknown",
        Icon = fishInfo and fishInfo.Icon or nil,
    }
end

