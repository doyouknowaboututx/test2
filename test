--## CONNECTION NOTIFICATION
local remote = api.Events.Notification
if remote and remote:IsA("RemoteEvent") then
    remote.OnClientEvent:Connect(function(message)
        if typeof(message) ~= "string" then
            return
        end

        if not string.find(message, "%[Server%]") then
            return
        end

        local data = parseFishMessage(message)
        if not data then
            return
        end

        local fishInfo = getFishInfo(data.Fish)
        if not fishInfo then
            return
        end

        sendFishWebhook(data)
    end)
else
    warn("Notification remote not found")
end

