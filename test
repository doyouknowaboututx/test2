--## CHECK HASH REMOTE NAME
local function isHash(name)
    local suffix = name:match("^[%u]+/(.+)$")
    return suffix and #suffix == 64 and suffix:match("^[a-f0-9]+$")
end

--## REMOTE CACHE
local chx = {}
local children = mods.Net:GetChildren()

for i, child in ipairs(children) do
    if not isHash(child.Name) then
        local nextChild = children[i + 1]

        if nextChild and isHash(nextChild.Name) then
            chx[child.Name] = nextChild
        end
    end
end

--## GET REMOTE EVENT
local function RE(name)
    return chx["RE/" .. name]
end

